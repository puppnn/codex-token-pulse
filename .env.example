SUB2API_MONITOR_MODE=auto
SUB2API_BASE_URL=http://127.0.0.1:8080
SUB2API_ADMIN_EMAIL=admin@sub2api.local
SUB2API_ADMIN_PASSWORD=

# Optional local usage settings
CLIENT_USAGE_CODEX_DEFAULT_MODEL=gpt-5.5
CLIENT_USAGE_MAX_SINGLE_EVENT_TOKENS=2000000
SUB2API_INCLUDE_LOCAL_USAGE=false
SUB2API_MONITOR_USAGE_SOURCE=auto
SUB2API_MATCH_BASE_URLS=
SUB2API_USAGE_HISTORY_JSON=

# Optional runtime behavior
SUB2API_CLIENT_USAGE_PYTHON=
SUB2API_CLIENT_USAGE_CACHE_SECONDS=10
SUB2API_CLIENT_USAGE_EXPORT_TIMEOUT_SECONDS=15
SUB2API_ACCOUNT_WINDOW_CACHE_SECONDS=60
SUB2API_LOCAL_ACTIVE_WINDOW_SECONDS=300

# Optional Codex local accounting
CLIENT_USAGE_CODEX_FAST_COST_MULTIPLIER=2.0
CLIENT_USAGE_CODEX_FORCE_SPEED=
CLIENT_USAGE_CODEX_SPEED_OVERRIDES=
CLIENT_USAGE_CONFIG=
CLIENT_USAGE_SPEED_HISTORY=
CLIENT_USAGE_CODEX_DESKTOP_LOG_ROOT=

# Optional multi-machine usage over Tailscale.
# Collector example: build=http://100.87.128.74:8765;gpu=http://gpu-box:8765
TOKEN_PULSE_LOCAL_NODE_ID=
TOKEN_PULSE_REMOTE_NODES=
TOKEN_PULSE_REMOTE_TOKEN=
TOKEN_PULSE_REMOTE_TIMEOUT_SECONDS=5
# Remote-agent bind settings (used on each remote machine).
TOKEN_PULSE_REMOTE_HOST=tailscale
TOKEN_PULSE_REMOTE_PORT=8765
